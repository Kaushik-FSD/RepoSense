GROQ_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
MISTRAL_API_KEY=

GROQ_MODEL=llama-3.3-70b-versatile
MISTRAL_MODEL=mistral-small-2603

# To change the LLM provider, set LLM_PROVIDER to either "groq" or "mistral"
LLM_PROVIDER=groq

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./storage/chroma

RETRIEVAL_TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

APP_NAME=AI Dev Assistant
APP_VERSION=0.1.0
DEBUG=false